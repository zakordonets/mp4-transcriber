# Whisper / ASR configuration
WHISPER_MODEL=base
LANGUAGE=ru
DEVICE=cpu
OUTPUT_DIR=./transcripts
MAX_WORKERS=2
LOG_LEVEL=INFO

# Optional: use the pyannote diarization backend by default when `--diarize` is set.
DIARIZATION_BACKEND=pyannote

# Optional: Hugging Face token for pyannote speaker diarization.
# Use one of the following names. The app accepts either.
# HF_TOKEN=hf_your_token_here
# HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# Optional: CPU tuning for long transcriptions.
# Set these to the number of physical cores on your machine if you want a fixed cap.
# OMP_NUM_THREADS=6
# MKL_NUM_THREADS=6
